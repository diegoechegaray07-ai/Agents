# Normalizar todo a LF para evitar diffs fantasma por line-endings
# (en junio 2026 una herramienta convirtió 54 .xsd a CRLF sin cambio real)
* text=auto eol=lf

# Binarios: nunca normalizar
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.pdf binary
*.xlsx binary
*.docx binary
*.pptx binary
